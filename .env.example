# ── Claude API ─────────────────────────────────────────────────────────────────
# Get your key at https://console.anthropic.com/
GEMINI_API_KEY=

# ── VPS Sync endpoint ──────────────────────────────────────────────────────────
# URL served by n8n / nginx that returns the latest sleep JSON payload
# Format: { "sleep": [...], "generatedAt": "<ISO>" }
SYNC_ENDPOINT_URL=https://your-vps.example.com/sleepiq/latest.json

# Optional auth token sent as X-SleepIQ-Token header
SYNC_SECRET_TOKEN=your-secret-token
