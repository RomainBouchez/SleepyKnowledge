# Claude API Key (https://console.anthropic.com/)
CLAUDE_API_KEY=sk-ant-...

# Sync endpoint (URL where n8n/VPS pushes sleep data JSON)
# e.g. a Nextcloud WebDAV file, or a protected n8n endpoint
SYNC_ENDPOINT_URL=https://your-vps.example.com/sleepiq/sync

# Optional: secret token to authenticate sync requests
SYNC_SECRET_TOKEN=your-secret-token
